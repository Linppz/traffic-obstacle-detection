# feat-006 backend env template — 复制为 .env 后按本机实际值填写

# ---- MySQL ----
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=yolo_traffic
MYSQL_USER=yolo_user
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_root

# ---- JDK 21 路径（macOS Homebrew 默认值；其他机器改为本机路径） ----
JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home

# ---- JWT（生产部署必须替换为强随机字符串） ----
JWT_SECRET=please_replace_with_long_random_secret_at_least_32_bytes
JWT_ACCESS_TTL_HOURS=2
JWT_REFRESH_TTL_DAYS=7

# ---- FastAPI 推理服务上游 ----
INFER_BASE_URL=http://127.0.0.1:8001
INFER_CONNECT_TIMEOUT_MS=3000
INFER_READ_TIMEOUT_MS=60000
INFER_VIDEO_READ_TIMEOUT_MS=300000

# ---- 文件存储根路径（绝对路径，建议指向空目录） ----
STORAGE_ROOT=/ABSOLUTE/PATH/TO/storage

# ---- LLM（智能问答；留空则走占位答案不真正联网） ----
LLM_PROVIDER=qwen
LLM_MODEL=qwen-vl-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_CONNECT_TIMEOUT_MS=5000
LLM_READ_TIMEOUT_MS=30000
